Algoritmo Ejemplo17
	n = 3
	i = 1
	Dimensionar numeros(n)
	Mientras i<=3 Hacer
		Escribir 'Introduzca un elemento ', i, ' del vector numeros'
		Leer numeros[i]
		i = i+1
	FinMientras
	Escribir 'Los numeros declarados en un arreglo son'
	para i = 1 Hasta 3 Hacer
		escribir numeros[i], " " 	
	FinPara
FinAlgoritmo

