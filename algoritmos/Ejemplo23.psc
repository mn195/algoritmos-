Algoritmo Ejemplo23
	i <- 1
	Dimensionar numeros(5)
	Mientras i<=5 Hacer
		Escribir 'Introduzca un elemento ', i, ' del vector numeros'
		Leer numeros[i]
		i <- i+1
	FinMientras
	Escribir 'Los numeros declarados en un arreglo son'
	para i = 1 Hasta 5 Hacer
		escribir numeros[i], " " 	
	FinPara
FinAlgoritmo
